rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Bootstrap admin: seu email de desenvolvedor
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'jonny2005ster@gmail.com';
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && (isBootstrapAdmin() || getRole() == 'admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.size() >= 4 &&
               data.role in ['employee', 'admin'] &&
               data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               data.email is string && data.email.size() > 0;
      }

      // Read: Allow public lookup by ID (email or UID) to support login/registration
      // and finding email by name (which uses a query list)
      allow get: if true;
      allow list: if true;
      
      // CREATE/UPDATE/DELETE: Only the Master user (Bootstrap) or existing Admin can manage employees
      // Exception: Allow a newly authenticated user to create their own UID doc if their authenticated email matches.
      allow create: if (isBootstrapAdmin() || isAdmin()) || 
                    (isOwner(userId) && request.resource.data.email == request.auth.token.email);
      
      allow update: if (isBootstrapAdmin() || isAdmin()) || 
                    (isOwner(userId) && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'photoURL', 'cpf', 'uid', 'status']));

      allow delete: if isBootstrapAdmin() || isAdmin() || 
                    (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // --- Time Entries Collection ---
    match /timeEntries/{entryId} {
      function isValidTimeEntry(data) {
        return data.userId == request.auth.uid &&
               data.type in ['in', 'out'] &&
               data.timestamp == request.time &&
               data.userName is string;
      }

      // Users can list their own entries, admins can list all
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Users can create their own entries
      allow create: if isSignedIn() && isValidTimeEntry(request.resource.data);
      
      // Only admins can delete entries
      allow delete: if isAdmin();
    }
  }
}
